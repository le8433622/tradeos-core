# TradeOS Core — Environment Variables
# Copy this file to .env and fill in secrets from 1Password vault "TradeOS Core".
# See docs/11_SECRETS_REFERENCE.md for detailed instructions.
#
# Load all secrets from 1Password:
#   ./scripts/load-env.sh > .env

# ── Database ──────────────────────────────────────────────────────────────
# Staging (local dev):    postgresql://postgres:PASSWORD@db.ulnjanlaehfmxurreibj.supabase.co:5432/postgres
# Production (pooler):    postgresql://postgres.okkzfmtwrjkfjzyprrwh:PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres
# Production (direct):    postgresql://postgres:PASSWORD@db.okkzfmtwrjkfjzyprrwh.supabase.co:5432/postgres
DATABASE_URL=""
DIRECT_URL=""

# ── Supabase Auth ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=""
# Only enable in local development; must be false in production
ALLOW_DEMO_AUTH="true"

# ── Webhooks ──────────────────────────────────────────────────────────────
WEBHOOK_SECRET=""
WEBHOOK_ENCRYPTION_KEY=""

# ── Email ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=""

# ── App ───────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ── External AI (optional) ────────────────────────────────────────────────
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
REDIS_URL=""

# ── E2E / Playwright ──────────────────────────────────────────────────────
E2E_USER_PASSWORD=""

# ── Kill Switches (local = false to enable features) ─────────────────────
AI_EXECUTION_ENABLED="false"
EXTERNAL_TOOLCALL_ENABLED="false"
WEBHOOK_PROCESSING_ENABLED="false"
WORKER_CONSUMING_ENABLED="false"
BILLING_SIDE_EFFECTS_ENABLED="false"
PLUGIN_EXECUTION_ENABLED="false"
