{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM"]
  },
  "exclude": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
  "include": ["src/**/*.ts", "vitest.config.ts"]
}
