generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrganizationType {
  IMPORTER
  EXPORTER
  DISTRIBUTOR
  LOGISTICS
  SERVICE
  ASSOCIATION
  OTHER
}

enum UserRole {
  OWNER
  ADMIN
  SALES
  OPERATOR
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  WON
  LOST
}

enum CompanyType {
  BUYER
  SELLER
  PARTNER
  LOGISTICS
  SERVICE
  OTHER
}

enum ChannelType {
  WEB
  ZALO
  WHATSAPP
  EMAIL
  TELEGRAM
  MANUAL
}

enum SenderType {
  USER
  CUSTOMER
  AI
  SYSTEM
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ActionRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType @default(OTHER)
  country   String?
  website   String?
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  users         User[]
  companies     Company[]
  leads         Lead[]
  products      Product[]
  conversations Conversation[]
  tasks         Task[]
  quotations    Quotation[]
  notifications Notification[]
  auditLogs     AuditLog[]
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  email          String       @unique
  name           String?
  role           UserRole     @default(VIEWER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks        Task[]
  auditLogs    AuditLog[]
}

model Company {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  country        String?
  industry       String?
  type           CompanyType @default(OTHER)
  website        String?
  notes          String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  leads        Lead[]
  deals        Deal[]
}

model Contact {
  id        String   @id @default(cuid())
  companyId String?
  name      String?
  email     String?
  phone     String?
  title     String?
  country   String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  companyId      String?
  source         String
  name           String?
  phone          String?
  email          String?
  need           String?
  status         LeadStatus @default(NEW)
  score          Int        @default(0)
  aiSummary      String?
  nextAction     String?
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals        Deal[]
  tasks        Task[]
  quotations   Quotation[]
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  category       String?
  description    String?
  originCountry  String?
  priceRange     String?
  moq            String?
  certification  String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Deal {
  id        String   @id @default(cuid())
  companyId String?
  leadId    String?
  title     String
  stage     String   @default("new")
  value     Decimal?
  currency  String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model Conversation {
  id             String      @id @default(cuid())
  organizationId String
  channel        ChannelType
  externalId     String?
  title          String?
  aiSummary      String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages      Message[]
}

model Message {
  id             String     @id @default(cuid())
  conversationId String
  senderType     SenderType
  content        String
  metadata       Json?
  createdAt      DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Quotation {
  id             String          @id @default(cuid())
  organizationId String
  leadId         String?
  title          String
  content        String
  status         QuotationStatus @default(DRAFT)
  totalAmount    Decimal?
  currency       String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model Task {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String?
  assigneeId     String?
  title          String
  description    String?
  status         String   @default("open")
  dueAt          DateTime?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignee     User?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String?
  title          String
  body           String
  audience       String   @default("organization")
  status         String   @default("draft")
  metadata       Json?
  createdAt      DateTime @default(now())
  publishedAt    DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String          @id @default(cuid())
  organizationId String?
  actorUserId    String?
  actionName     String
  riskLevel      ActionRiskLevel @default(LOW)
  input          Json?
  result         Json?
  approved       Boolean         @default(false)
  createdAt      DateTime        @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}
