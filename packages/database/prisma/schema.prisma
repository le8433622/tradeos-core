generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrganizationType {
  IMPORTER
  EXPORTER
  DISTRIBUTOR
  LOGISTICS
  SERVICE
  ASSOCIATION
  OTHER
}

enum UserRole {
  OWNER
  ADMIN
  SALES
  OPERATOR
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  WON
  LOST
}

enum CompanyType {
  BUYER
  SELLER
  PARTNER
  LOGISTICS
  SERVICE
  OTHER
}

enum ChannelType {
  WEB
  ZALO
  WHATSAPP
  EMAIL
  TELEGRAM
  MANUAL
}

enum SenderType {
  USER
  CUSTOMER
  AI
  SYSTEM
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ActionRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTING
  EXECUTED
  FAILED
}

enum WebhookEventStatus {
  RECEIVED
  DUPLICATE
  BLOCKED
  PROCESSED
  FAILED
}

enum IntegrationStatus {
  ACTIVE
  DISABLED
}

enum JobType {
  PROCESS_WEBHOOK_EVENT
  ARCHIVE_WEBHOOK_PAYLOADS
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TenantPlan {
  FREE
  PILOT
  TEAM
  ASSOCIATION
  ENTERPRISE
}

enum MemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

model Organization {
  id             String           @id @default(cuid())
  name           String
  type           OrganizationType @default(OTHER)
  plan           TenantPlan       @default(FREE)
  legalHold      Boolean          @default(false)
  country        String?
  website        String?
  avgDealValue   Decimal?
  conversionRate Float?
  aiMonthlyBudget Decimal? @default(0)
  metadata       Json?
  introductionsEnabled Boolean @default(false)
  mfaRequired      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  users            User[]
  members          OrganizationMember[]
  invitations      Invitation[]
  companies        Company[]
  contacts         Contact[]
  leads            Lead[]
  products         Product[]
  conversations    Conversation[]
  tasks            Task[]
  quotations       Quotation[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  approvalRequests ApprovalRequest[]
  webhookEvents    WebhookEvent[]
  webhookIntegrations WebhookIntegration[]
  jobs                Job[]
  aiUsageEvents       AiUsageEvent[]
  reportSnapshots     ReportSnapshot[]
  proposedIntroductions IntroductionRequest[] @relation("ProposerOrg")
  targetIntroductions    IntroductionRequest[] @relation("TargetOrg")
  partnerIntroductions   IntroductionRequest[] @relation("PartnerOrg")
  deals                  Deal[]
  sourcingRuns           SourcingRun[]
  payments               Payment[]

  @@index([plan])
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  email          String       @unique
  name           String?
  role           UserRole     @default(VIEWER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization             Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks                    Task[]
  auditLogs                AuditLog[]
  requestedApprovals       ApprovalRequest[]  @relation("ApprovalRequester")
  reviewedApprovals        ApprovalRequest[]  @relation("ApprovalReviewer")
  approvedSnapshots        ReportSnapshot[]   @relation("SnapshotApprover")
  memberships              OrganizationMember[]
}

model Company {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  country        String?
  industry       String?
  type           CompanyType @default(OTHER)
  website        String?
  notes          String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  leads        Lead[]
  deals        Deal[]
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  companyId      String?
  name           String?
  email          String?
  phone          String?
  title          String?
  country        String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  companyId      String?
  source         String
  name           String?
  phone          String?
  email          String?
  need           String?
  status         LeadStatus @default(NEW)
  score          Int        @default(0)
  aiSummary      String?
  nextAction     String?
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals        Deal[]
  tasks        Task[]
  quotations   Quotation[]
  sourcingRuns SourcingRun[]
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  category       String?
  description    String?
  originCountry  String?
  priceRange     String?
  moq            String?
  certification  String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quotationLineItems QuotationLineItem[]
}

model Deal {
  id             String   @id @default(cuid())
  organizationId String
  companyId      String?
  leadId         String?
  title          String
  stage          String   @default("new")
  value          Decimal?
  currency       String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

model Conversation {
  id             String      @id @default(cuid())
  organizationId String
  channel        ChannelType
  externalId     String?
  title          String?
  aiSummary      String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages      Message[]
}

model Message {
  id             String     @id @default(cuid())
  conversationId String
  senderType     SenderType
  content        String
  metadata       Json?
  createdAt      DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Quotation {
  id             String          @id @default(cuid())
  organizationId String
  leadId         String?
  title          String
  content        String
  status         QuotationStatus @default(DRAFT)
  totalAmount    Decimal?
  currency       String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  lineItems    QuotationLineItem[]
}

model QuotationLineItem {
  id           String   @id @default(cuid())
  quotationId  String
  productId    String?
  description  String
  quantity     Decimal
  unit         String?
  unitPrice    Decimal
  currency     String?
  totalAmount  Decimal?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Task {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String?
  assigneeId     String?
  title          String
  description    String?
  status         String   @default("open")
  dueAt          DateTime?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignee     User?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  body           String
  audience       String   @default("organization")
  status         String   @default("draft")
  metadata       Json?
  createdAt      DateTime @default(now())
  publishedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String          @id @default(cuid())
  organizationId String
  actorUserId    String?
  actionName     String
  riskLevel      ActionRiskLevel @default(LOW)
  input          Json?
  result         Json?
  approved       Boolean         @default(false)
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}

model ApprovalRequest {
  id             String          @id @default(cuid())
  organizationId String
  requestedById  String?
  reviewedById   String?
  actionName     String
  riskLevel      ActionRiskLevel @default(HIGH)
  status         ApprovalStatus  @default(PENDING)
  input          Json
  reason         String?
  reviewNote     String?
  result         Json?
  createdAt      DateTime        @default(now())
  reviewedAt     DateTime?
  executedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy  User?        @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy   User?        @relation("ApprovalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
}

model WebhookEvent {
  id             String             @id @default(cuid())
  organizationId String
  channel        ChannelType
  eventKey       String
  status         WebhookEventStatus @default(RECEIVED)
  sourceIp       String?
  payload        Json?
  result         Json?
  error          String?
  receivedAt     DateTime           @default(now())
  processedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, channel, eventKey])
  @@index([organizationId, channel, receivedAt])
}

model WebhookIntegration {
  id                String            @id @default(cuid())
  organizationId    String
  channel           ChannelType
  providerAccountId String
  secretHash        String
  status            IntegrationStatus @default(ACTIVE)
  createdAt         DateTime          @default(now())
  rotatedAt         DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([channel, providerAccountId])
  @@index([organizationId])
}

model Job {
  id             String    @id @default(cuid())
  organizationId String
  type           JobType
  status         JobStatus @default(PENDING)
  payload        Json?
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  nextRunAt      DateTime  @default(now())
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status, nextRunAt])
  @@index([organizationId, type, createdAt])
}

model AiUsageEvent {
  id             String   @id @default(cuid())
  organizationId String
  feature        String
  provider       String   @default("openai")
  model          String
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  estimatedCost  Decimal  @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  roleId         String?
  status         MemberStatus @default(INVITED)
  invitedAt      DateTime?
  acceptedAt     DateTime?
  suspendedAt    DateTime?
  mfaEnrolledAt  DateTime?
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Role {
  id             String            @id @default(cuid())
  name           String
  description    String?
  isSystem       Boolean           @default(false)
  organizationId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  memberships OrganizationMember[]
  permissions  RolePermission[]
  invitations  Invitation[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  group       String?

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  roleId         String?
  tokenHash      String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([tokenHash])
  @@index([organizationId, email])
}

enum ReportSnapshotStatus {
  DRAFT
  APPROVED
  DISTRIBUTED
}

model ReportSnapshot {
  id             String                 @id @default(cuid())
  organizationId String
  reportType     String                 @default("weekly")
  periodStart    String
  periodEnd      String
  payload        Json
  status         ReportSnapshotStatus   @default(DRAFT)
  approvedById   String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvedBy   User?        @relation("SnapshotApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([organizationId, reportType, createdAt])
  @@index([organizationId, status])
}

enum IntroductionStatus {
  PENDING_BUYER_APPROVAL
  PENDING_SELLER_APPROVAL
  APPROVED
  REJECTED
  DISPUTED
}

model IntroductionRequest {
  id              String              @id @default(cuid())
  proposerOrgId   String
  buyerOrgId      String
  sellerOrgId     String
  status          IntroductionStatus  @default(PENDING_BUYER_APPROVAL)
  buyerNote       String?
  sellerNote      String?
  disputeReason   String?
  valueGenerated  String?
  buyerContactId  String?
  sellerContactId String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  proposerOrg Organization @relation("ProposerOrg", fields: [proposerOrgId], references: [id], onDelete: Cascade)
  buyerOrg    Organization @relation("TargetOrg", fields: [buyerOrgId], references: [id], onDelete: Cascade)
  sellerOrg   Organization @relation("PartnerOrg", fields: [sellerOrgId], references: [id], onDelete: Cascade)

  @@index([proposerOrgId])
  @@index([buyerOrgId])
  @@index([sellerOrgId])
  @@index([status])
}

enum SourcingRunStatus {
  DRAFT
  ACTIVE
  SUPPLIER_SHORTLISTED
  QUOTES_COLLECTED
  COMPARED
  READY_FOR_REVIEW
  REPORT_DELIVERED
  CANCELLED
}

enum SupplierStatus {
  DISCOVERED
  CONTACTED
  QUOTED
  SELECTED
  REJECTED
}

enum EvidenceType {
  SUPPLIER_MESSAGE
  CALL_NOTE
  QUOTE_SCREENSHOT
  QUOTE_FILE
  INVOICE
  PAYMENT_PROOF
  APPROVAL_RECORD
  DELIVERY_CONFIRMATION
  COMPARISON_TABLE
  BUYER_DECISION
  SYSTEM_LOG
  CURRENT_SUPPLIER_INVOICE
  CURRENT_SUPPLIER_PRICE_LIST
  ALTERNATIVE_QUOTE
  ALTERNATIVE_PROFILE
  MARKET_BENCHMARK
  SWITCH_DECISION_REPORT
  OUTCOME_EVIDENCE
  NEGOTIATION_LOG
}

enum CheckpointStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  APPROVED
  REJECTED
  BILLED
}

enum CheckpointType {
  PAID_SOURCING_REQUEST
  SUPPLIER_SHORTLIST
  QUOTE_COLLECTION
  QUOTE_COMPARISON
  NEGOTIATION_RUN
  BUYER_DECISION_REPORT
  INTRODUCTION
  DEAL_SUCCESS
}

enum HandoverStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum HandoverReason {
  PRICE_THRESHOLD
  ABNORMAL_SUPPLIER
  UNCLEAR_PAYMENT
  LEGAL_AMBIGUITY
  SHIPPING_AMBIGUITY
  BUYER_PREFERENCE_CONFLICT
  LOW_CONFIDENCE
  MONEY_MOVEMENT
  FINAL_ORDER
  OTHER
}

model SourcingRun {
  id              String            @id @default(cuid())
  organizationId  String
  leadId          String?
  title           String
  requirement     String
  status          SourcingRunStatus @default(DRAFT)
  targetCountry   String?
  sourceCountry   String?
  productCategory String?
  quantity        String?
  budget          String?
  currency        String?
  riskLevel       String            @default("MEDIUM")
  createdById     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead             Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  supplierCandidates SupplierCandidate[]
  supplierQuotes    SupplierQuote[]
  evidenceItems      EvidenceItem[]
  checkpoints        WorkCheckpoint[]
  handovers          HumanHandover[]
  purchaseBaselines  PurchaseBaseline[]
  supplierAlternatives SupplierAlternative[]
  switchDecisionReports SwitchDecisionReport[]

  @@index([organizationId, status])
  @@index([leadId])
}

model PurchaseBaseline {
  id                 String   @id @default(cuid())
  organizationId     String
  sourcingRunId      String

  supplierName       String
  supplierContact    Json?
  sourceType         String   @default("MANUAL")
  sourceEvidenceId   String?

  productDescription String
  quantity           Decimal?
  unit               String?
  unitPrice          Decimal?
  currency           String?
  frequency          String?
  annualEquivalent   Decimal?

  paymentTerms   String?
  deliveryTerms  String?
  leadTime       String?
  minOrderQty    String?

  riskFlags    Json?
  leakageScore Int?
  marketPrice  Decimal?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sourcingRun SourcingRun @relation(fields: [sourcingRunId], references: [id], onDelete: Cascade)

  @@index([organizationId, sourcingRunId])
}

model SwitchDecisionReport {
  id                  String   @id @default(cuid())
  organizationId      String
  sourcingRunId       String

  recommendation      String   // SWITCH | NEGOTIATE | WAIT
  confidence          String   // HIGH | MEDIUM | LOW

  savingsScore        Int?
  evidenceScore       Int?
  paymentRiskScore    Int?
  leadTimeRiskScore   Int?
  dependencyRiskScore Int?
  overallScore        Int?

  monthlySavings      Decimal?
  annualSavings       Decimal?
  savingsPercent      Decimal?
  currency            String?

  baselineId          String?
  topAlternativeId    String?

  evidenceSummary     Json?
  missingProof        Json?
  riskFlags           Json?

  summary             String?
  nextActions         Json?

  buyerDecision       String?   // APPROVED | REQUEST_MORE_PROOF | REJECTED
  buyerDecidedAt      DateTime?
  buyerDecidedById    String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sourcingRun SourcingRun @relation(fields: [sourcingRunId], references: [id], onDelete: Cascade)

  @@index([organizationId, sourcingRunId])
}

model SupplierAlternative {
  id                  String   @id @default(cuid())
  organizationId      String
  sourcingRunId       String
  supplierCandidateId String?

  supplierName        String
  productDescription  String
  quantity            Decimal?
  unit                String?
  unitPrice           Decimal?
  totalCost           Decimal?
  currency            String?
  moq                 String?
  leadTime            String?
  paymentTerm         String?
  warranty            String?
  shippingNotes       String?
  riskFlags           Json?

  estimatedSavings    Decimal?
  savingsConfidence   Int?
  switchingCost       String?
  switchingRisk       String?
  totalCostComparison Json?

  evidenceId  String?
  status      String   @default("DISCOVERED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sourcingRun       SourcingRun        @relation(fields: [sourcingRunId], references: [id], onDelete: Cascade)
  supplierCandidate SupplierCandidate? @relation(fields: [supplierCandidateId], references: [id], onDelete: SetNull)

  @@index([organizationId, sourcingRunId])
}

model SupplierCandidate {
  id               String         @id @default(cuid())
  organizationId   String
  sourcingRunId    String
  name             String
  source           String?
  website          String?
  platform         String?
  country          String?
  contactInfo      Json?
  reliabilityScore Int?
  riskFlags        Json?
  status           SupplierStatus @default(DISCOVERED)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  sourcingRun SourcingRun   @relation(fields: [sourcingRunId], references: [id], onDelete: Cascade)
  quotes      SupplierQuote[]
  supplierAlternatives SupplierAlternative[]

  @@index([organizationId, sourcingRunId])
}

model SupplierQuote {
  id                  String       @id @default(cuid())
  organizationId      String
  sourcingRunId       String
  supplierCandidateId String?
  productDescription  String
  quantity            Decimal?
  unit                String?
  unitPrice           Decimal?
  totalAmount         Decimal?
  currency            String?
  moq                 String?
  leadTime            String?
  shippingTerm        String?
  paymentTerm         String?
  warranty            String?
  riskScore           Int?
  comparisonRank      Int?
  status              String       @default("COLLECTED")
  rawData             Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  sourcingRun       SourcingRun        @relation(fields: [sourcingRunId], references: [id], onDelete: Cascade)
  supplierCandidate SupplierCandidate? @relation(fields: [supplierCandidateId], references: [id], onDelete: SetNull)

  @@index([organizationId, sourcingRunId])
}

model EvidenceItem {
  id             String   @id @default(cuid())
  organizationId String
  sourcingRunId  String?
  relatedType    String
  relatedId      String?
  evidenceType   EvidenceType
  title          String
  description    String?
  content        String?
  fileUrl        String?
  externalUrl    String?
  hash           String?
  metadata       Json?
  capturedBy     String?
  capturedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  sourcingRun SourcingRun? @relation(fields: [sourcingRunId], references: [id], onDelete: Cascade)

  @@index([organizationId, relatedType, relatedId])
  @@index([sourcingRunId])
}

model WorkCheckpoint {
  id             String           @id @default(cuid())
  organizationId String
  sourcingRunId  String?
  title          String
  description    String?
  checkpointType CheckpointType
  status         CheckpointStatus @default(PENDING)
  price          Decimal?
  currency       String?
  payerOrgId     String?
  evidenceCount  Int              @default(0)
  approvedById   String?
  approvedAt     DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  sourcingRun SourcingRun? @relation(fields: [sourcingRunId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@index([organizationId, status])
  @@index([sourcingRunId])
}

model HumanHandover {
  id                    String           @id @default(cuid())
  organizationId        String
  sourcingRunId         String?
  reason                HandoverReason
  riskLevel             String
  context               Json
  recommendedNextAction String?
  status                HandoverStatus @default(OPEN)
  assignedToId          String?
  resolvedById          String?
  resolvedAt            DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  sourcingRun SourcingRun? @relation(fields: [sourcingRunId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model Payment {
  id                 String         @id @default(cuid())
  organizationId     String
  checkpointId       String
  invoiceId          String?
  amount             Decimal
  currency           String         @default("USD")
  externalPaymentId   String?
  provider           String         @default("manual")
  status             PaymentStatus  @default(COMPLETED)
  paidAt             DateTime       @default(now())
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  checkpoint   WorkCheckpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, checkpointId])
  @@index([organizationId, paidAt])
  @@unique([provider, externalPaymentId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model PlanLimit {
  id             String @id @default(cuid())
  plan           TenantPlan
  feature        String
  limitValue     Int
  unit           String @default("count")
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([plan, feature])
}
